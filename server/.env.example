# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/iqraa_school

# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string

# وضع التطوير التجريبي — يملأ الموقع ببيانات تجريبية ويعيد ضبط كلمات المرور
# للعرض أمام المدارس الحقيقية: DEMO_MODE=false
DEMO_MODE=true

# النسخ الاحتياطي التلقائي لبيانات المدرسة
BACKUP_AUTO=true
BACKUP_ON_START=true
BACKUP_DIR=./backups
BACKUP_HOUR=3
BACKUP_RETENTION_DAYS=30
BACKUP_MAX_FILES=60
BACKUP_CHECK_MS=900000
