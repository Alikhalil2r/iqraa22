# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Windows local example:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/iqraa_school

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Required — generate a long random string (see SECRETS.md in repo root)
# Minimum 32 characters recommended for production
JWT_SECRET=change-me-to-a-long-random-string

# ─── Demo mode ────────────────────────────────────────────────────────────────
# true  = seed demo school data and reset demo passwords on startup (development)
# false = production — no demo seeding; DEMO_MODE=true is blocked when NODE_ENV=production
DEMO_MODE=true

# ─── Automatic backups ───────────────────────────────────────────────────────
BACKUP_AUTO=true
BACKUP_ON_START=true
BACKUP_DIR=./backups
BACKUP_HOUR=3
BACKUP_RETENTION_DAYS=30
BACKUP_MAX_FILES=60
BACKUP_CHECK_MS=900000

# ─── Auth refresh (POC) ───────────────────────────────────────────────────────
# true = refresh token in httpOnly cookie; false = returned in JSON body
AUTH_REFRESH_COOKIE=false
# Enforce 2FA for admin/super_admin (auto-off when DEMO_MODE=true)
ADMIN_2FA_REQUIRED=true

# ─── Payments (mock by default) ─────────────────────────────────────────────
PAYMENT_MOCK_MODE=true
PAYMENT_WEBHOOK_SECRET=
PUBLIC_URL=http://localhost:5000

# ─── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=debug

# ─── Email / SMS (optional) ───────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@iqraa.demo
SMS_PROVIDER=stub
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── File uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
S3_BUCKET=
S3_ENDPOINT=
S3_PUBLIC_URL=
