# ─── Iqraa School — Production environment template ───────────────────────────
# Copy to server/.env on your host (never commit real values).
# See SECRETS.md and GO-LIVE.md in the repo root for full guidance.

# ─── PostgreSQL (required) ────────────────────────────────────────────────────
# Use TLS in production: append ?sslmode=require when supported by your host
DATABASE_URL=postgresql://iqraa_app:CHANGE_ME@db.example.com:5432/iqraa_school?sslmode=require

# ─── Server (required) ────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# Required — generate 32+ random characters (see SECRETS.md)
JWT_SECRET=CHANGE_ME_GENERATE_32_PLUS_RANDOM_CHARS

# Must be false in production (server blocks DEMO_MODE=true when NODE_ENV=production)
DEMO_MODE=false

# Public URL of the deployed app (used for payment redirects and webhooks)
PUBLIC_URL=https://school.example.com

# Comma-separated allowed browser origins (e.g. https://school.example.com)
CORS_ORIGINS=https://school.example.com

# ─── Auth & security ──────────────────────────────────────────────────────────
# true = refresh token in httpOnly cookie; false = returned in JSON body
AUTH_REFRESH_COOKIE=true
# Enforce 2FA for admin/super_admin accounts
ADMIN_2FA_REQUIRED=true

# ─── Payments ─────────────────────────────────────────────────────────────────
# false = live gateway; true = mock sessions (dev/staging only)
PAYMENT_MOCK_MODE=false
# Shared secret to verify provider webhook signatures
PAYMENT_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET
# Thawani / PayTabs keys — configure when integrating live gateways
# THAWANI_SECRET_KEY=
# THAWANI_PUBLISHABLE_KEY=
# PAYTABS_PROFILE_ID=
# PAYTABS_SERVER_KEY=

# ─── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info

# ─── Email (optional — or configure per-school via admin UI) ─────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@school.example.com

# ─── SMS (optional) ───────────────────────────────────────────────────────────
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── File uploads ─────────────────────────────────────────────────────────────
# Local fallback when S3 is not configured
UPLOAD_DIR=./uploads
S3_BUCKET=
S3_ENDPOINT=
S3_PUBLIC_URL=

# ─── Automatic backups ───────────────────────────────────────────────────────
BACKUP_AUTO=true
BACKUP_ON_START=true
BACKUP_DIR=./backups
BACKUP_HOUR=3
BACKUP_RETENTION_DAYS=30
BACKUP_MAX_FILES=60
BACKUP_CHECK_MS=900000
