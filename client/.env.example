# ─── Client (Vite) ───────────────────────────────────────────────────────────
# Only VITE_* variables are exposed to the browser.
# Copy to .env — never commit .env (see SECRETS.md in repo root).

# Show the demo-mode banner in the public UI (login pages always show demo credentials)
# true  = development / school demos
# false = marketing / production appearance
VITE_DEMO_MODE=false

# API URL: uses /api in dev (proxied to http://localhost:3001 via vite.config.ts)
# For a separate API host in production, configure your reverse proxy or build-time proxy.
